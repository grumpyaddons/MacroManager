package-as: MacroManager

move-folders:
  MacroManager/MacroManager: MacroManager
  MacroManager/MacroManagerData: MacroManagerData

ignore:
  - Makefile
  - psakefile.ps1
  - README.md
  - AGENTS.md
  - ui.png
  - linking-macro.png
  - ui-character-macro-snapshot.png

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
